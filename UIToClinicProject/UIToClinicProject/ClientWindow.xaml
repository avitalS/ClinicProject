<Window x:Class="UIToClinicProject.ClientWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="אזור אישי לקוח" Height="800" Width="1100" 
        FlowDirection="RightToLeft" WindowStartupLocation="CenterScreen">

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.3*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- עמודה ימנית: חיפור וקביעת תור -->
        <StackPanel Grid.Column="0" Margin="10">
            <Border Background="#F0F4F8" Padding="10" CornerRadius="5" Margin="0,0,0,15">
                <StackPanel Orientation="Horizontal">
                    <TextBlock x:Name="lblClientHeader" Text="טוען נתונים..." FontSize="16" FontWeight="Bold" Foreground="#2C3E50"/>
                    <Separator Width="20" Visibility="Hidden"/>
                    <TextBlock x:Name="lblLastVisit" Text="" FontSize="14" VerticalAlignment="Center" Foreground="#7F8C8D"/>
                </StackPanel>
            </Border>

            <TextBlock Text="חיפוש רופא וקביעת תור" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>

            <GroupBox Header="חיפוש וסינון" Padding="10" Margin="0,0,0,10">
                <StackPanel>
                    <TextBlock Text="חפש לפי התמחות:"/>
                    <ComboBox x:Name="cmbSpecialization" Margin="0,5" Height="30">
                        <ComboBoxItem Content="עיניים" Tag="Eyes"/>
                        <ComboBoxItem Content="משפחה" Tag="Family"/>
                        <ComboBoxItem Content="עור" Tag="Dermatology"/>
                        <ComboBoxItem Content="אף אוזן גרון" Tag="Ears"/>
                    </ComboBox>
                    <Button Content="🔍 חפש לפי התמחות" Click="BtnSearchBySpec_Click" Margin="0,5" Height="30"/>

                    <Separator Margin="0,10"/>

                    <TextBlock Text="חפש לפי עיר:"/>
                    <ComboBox x:Name="cmbCitySearch" Margin="0,5" Height="30">
                        <ComboBoxItem Content="ירושלים" Tag="Jerusalem"/>
                        <ComboBoxItem Content="תל אביב" Tag="Tel Aviv"/>
                        <ComboBoxItem Content="חיפה" Tag="Haifa"/>
                        <ComboBoxItem Content="אשדוד" Tag="Ashdod"/>
                        <ComboBoxItem Content="באר שבע" Tag="Beersheba"/>
                        <ComboBoxItem Content="אופקים" Tag="Ofakim"/>
                        <ComboBoxItem Content="נתיבות" Tag="Netivot"/>
                    </ComboBox>
                    <Button Content="📍 חפש לפי עיר" Click="BtnSearchByCity_Click" Margin="0,5" Height="30"/>
                </StackPanel>
            </GroupBox>

            <TextBlock Text="תוצאות חיפוש (בחר רופא):" Margin="0,10,0,5" FontWeight="SemiBold"/>
            <DataGrid x:Name="dgAvailableDoctors" Height="150" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="שם הרופא" Binding="{Binding FirstName}" Width="*"/>
                    <DataGridTextColumn Header="התמחות" Binding="{Binding Specialization}" Width="*"/>
                    <DataGridTextColumn Header="עיר" Binding="{Binding City}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>

            <UniformGrid Columns="2" Margin="0,15,0,0">
                <StackPanel Margin="0,0,5,0">
                    <TextBlock Text="בחר תאריך:"/>
                    <DatePicker x:Name="dpVisitDate" Margin="0,5"/>
                </StackPanel>
                <StackPanel Margin="5,0,0,0">
                    <TextBlock Text="רמת דחיפות:"/>
                    <ComboBox x:Name="cmbPriority" Margin="0,5" Height="30" SelectedIndex="1">
                        <ComboBoxItem Content="עדיפות 1 (5 דקות)"/>
                        <ComboBoxItem Content="עדיפות 2 (10 דקות)"/>
                        <ComboBoxItem Content="עדיפות 3 (15 דקות)"/>
                    </ComboBox>
                </StackPanel>
            </UniformGrid>

            <Button Content="✅ אשר קביעת תור" Click="BtnBookVisit_Click" Height="45" Margin="0,20,0,0" 
                    Background="#2980B9" Foreground="White" FontWeight="Bold"/>
        </StackPanel>

        <!-- עמודה שמאלית: תורים והיסטוריה -->
        <Grid Grid.Column="1" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Text="📅 התורים העתידיים שלי" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                <!-- שינוי מ-ListBox ל-DataGrid מותאם ל-SortedList -->
                <DataGrid x:Name="dgFutureVisits" Height="220" AutoGenerateColumns="False" IsReadOnly="True" BorderBrush="#DDD">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="תאריך ושעה" Binding="{Binding Key, StringFormat={}{0:dd/MM/yyyy HH:mm}}" Width="1.5*"/>
                        <DataGridTextColumn Header="קוד רופא" Binding="{Binding Value.DoctorId}" Width="*"/>
                        <DataGridTextColumn Header="דחיפות" Binding="{Binding Value.Priority}" Width="0.5*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>

            <StackPanel Grid.Row="1" Margin="0,20,0,0">
                <TextBlock Text="📜 היסטוריית ביקורים מלאה" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
                <DataGrid x:Name="dgVisitHistory" Height="220" AutoGenerateColumns="True" IsReadOnly="True" AlternatingRowBackground="#F9F9F9"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>