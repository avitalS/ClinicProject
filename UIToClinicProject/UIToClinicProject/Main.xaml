<Window x:Class="UIToClinicProject.Main"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="מערכת ניהול מרפאה" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2C3E50" Padding="20">
            <TextBlock Text="מערכת ניהול מרפאה" 
                       Foreground="White" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       HorizontalAlignment="Center"/>
        </Border>

        <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="40,0">
            <TextBlock Text="שלום, נא להזין מספר מזהה:" 
                       FontSize="14" 
                       Foreground="#7F8C8D" 
                       Margin="0,0,0,10"/>

            <TextBox x:Name="txtId" 
                     Height="40" 
                     FontSize="18" 
                     VerticalContentAlignment="Center"
                     BorderBrush="#BDC3C7"
                     BorderThickness="1"/>

            <Button Content="כניסה למערכת" 
                    Click="Login_Click" 
                    Height="45" 
                    Margin="0,25,0,0" 
                    Background="#2980B9" 
                    Foreground="White" 
                    FontSize="16" 
                    FontWeight="SemiBold"
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>

            <Button x:Name="btnRegister" 
                    Content="לקוח חדש? לחץ כאן להרשמה מהירה במערכת" 
                    Click="Register_Click" 
                    Margin="0,20,0,0" 
                    Padding="5" 
                    Background="Transparent" 
                    BorderThickness="0" 
                    Foreground="#2980B9" 
                    Cursor="Hand" 
                    FontSize="14" 
                    FontWeight="Medium"
                    HorizontalAlignment="Center">
                <Button.Style>
                    <Style TargetType="Button">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#1F618D"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

        </StackPanel>
    </Grid>
</Window>