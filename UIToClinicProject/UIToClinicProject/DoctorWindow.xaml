<Window x:Class="UIToClinicProject.DoctorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="אזור אישי - רופא" Height="800" Width="1100" 
        FlowDirection="RightToLeft" WindowStartupLocation="CenterScreen">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1.5*"/>
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <!-- עמודה ימנית: ניהול שכר וסטטיסטיקות -->
        <StackPanel Grid.Column="0" Margin="10">
            <TextBlock Text="ניהול שכר ובונוסים" FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>

            <GroupBox Header="חישוב בונוס" Padding="10">
                <StackPanel>
                    <TextBlock Text="הזן מכפיל בונוס:"/>
                    <TextBox x:Name="txtMult" Height="30" Margin="0,5" VerticalContentAlignment="Center"/>
                    <Button Content="💰 חשב בונוס שנתי לפי שנות הוותק שלך " Click="Calc_Click" Height="35" Background="#27AE60" Foreground="White" Margin="0,10,0,0"/>
                    <TextBlock x:Name="lblResult" FontSize="16" FontWeight="Bold" Foreground="DarkGreen" Margin="0,10,0,0" TextAlignment="Center"/>
                </StackPanel>
            </GroupBox>

            <Separator Margin="0,20"/>

            <TextBlock Text="📊 סטטיסטיקת ביקורים (Stored Procedure)" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
            <Button Content="🔍 טען נתוני סטטיסטיקה" Click="BtnCountVisits_Click" Height="35" Margin="0,0,0,10"/>

            <!-- DataGrid חדש להצגת הנתונים המפורטים מה-DTO -->
            <DataGrid x:Name="dgDoctorStats" 
                      AutoGenerateColumns="False" 
                      IsReadOnly="True" 
                      Height="117" 
                      Background="White" 
                      BorderBrush="#DDD"
                      AlternatingRowBackground="#F2F2F2">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="שם פרטי" Binding="{Binding FirstName}" Width="*"/>
                    <DataGridTextColumn Header="שם משפחה" Binding="{Binding LastName}" Width="*"/>
                    <DataGridTextColumn Header="התמחות" Binding="{Binding Specialization}" Width="*"/>
                    <DataGridTextColumn Header="סה''כ ביקורים" Binding="{Binding CountVisits}" Width="Auto" FontWeight="Bold"/>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>

        <!-- עמודה שמאלית: לו''ז ופירוט תורים -->
        <Grid Grid.Column="1" Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="150"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="לו''ז פגישות להיום :" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>

            <ListBox x:Name="lstDocSchedule" Grid.Row="1" Margin="0,0,0,10" BorderBrush="#CCC">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#EEE" BorderThickness="0,0,0,1" Padding="8">
                            <TextBlock Text="{Binding}" FontSize="14" Foreground="#34495E"/>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,10,0,10">
                <TextBlock Text="פירוט תורים כללי לתאריך:" FontSize="16" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <DatePicker x:Name="dpDetailedDate" Width="150" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <Button Content="🔍 הצג תורים" Click="BtnShowDetailed_Click" Padding="15,5" Background="#3498DB" Foreground="White" FontWeight="Bold"/>
            </StackPanel>

            <DataGrid x:Name="dgAllDoctorVisits" Grid.Row="3" AutoGenerateColumns="False" IsReadOnly="True" AlternatingRowBackground="#F9F9F9" Height="415" VerticalAlignment="Top">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="שם המטופל" Binding="{Binding PatientName}" Width="1.5*"/>
                    <DataGridTextColumn Header="שעה" Binding="{Binding Time, StringFormat={}{0:HH:mm}}" Width="*"/>
                    <DataGridTextColumn Header="התמחות" Binding="{Binding Specialization}" Width="*"/>
                    <DataGridTextColumn Header="שם רופא" Binding="{Binding DoctorName}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Window>