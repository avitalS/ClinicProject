<Window x:Class="UIToClinicProject.EditClientWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="עדכון פרטי לקוח" Height="650" Width="550"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <StackPanel VerticalAlignment="Center">

            <TextBlock x:Name="lblTitle" 
                       Text="עריכת פרטי לקוח" 
                       FontSize="22" 
                       FontWeight="Bold" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,25" 
                       Foreground="#2C3E50"/>

            <TextBlock Text="תעודת זהות:" Margin="0,10,0,5" Foreground="#7F8C8D" FontWeight="SemiBold"/>
            <TextBox x:Name="txtClientId" Height="35" FontSize="16" VerticalContentAlignment="Center"/>

            <TextBlock Text="שם מלא:" Margin="0,10,0,5" Foreground="#7F8C8D" FontWeight="SemiBold"/>
            <TextBox x:Name="txtFullName" Height="35" FontSize="16" VerticalContentAlignment="Center"/>

            <TextBlock Text="עיר:" Margin="0,10,0,5" Foreground="#7F8C8D" FontWeight="SemiBold"/>
            <TextBox x:Name="txtCity" Height="35" FontSize="16" VerticalContentAlignment="Center"/>

            <TextBlock Text="טלפון:" Margin="0,10,0,5" Foreground="#7F8C8D" FontWeight="SemiBold"/>
            <TextBox x:Name="txtPhone" Height="35" FontSize="16" VerticalContentAlignment="Center"/>

            <TextBlock Text="אימייל:" Margin="0,10,0,5" Foreground="#7F8C8D" FontWeight="SemiBold"/>
            <TextBox x:Name="txtEmail" Height="35" FontSize="16" VerticalContentAlignment="Center"/>

            <TextBlock Text="תאריך לידה:" Margin="0,10,0,5" Foreground="#7F8C8D" FontWeight="SemiBold"/>
            <DatePicker x:Name="dpBirthDate" Height="35" FontSize="16" VerticalContentAlignment="Center"/>

            <TextBlock Text="סיסמה:" Margin="0,10,0,5" Foreground="#7F8C8D" FontWeight="SemiBold"/>
            <TextBox x:Name="txtPass" Height="35" FontSize="16" VerticalContentAlignment="Center"/>

            <Button x:Name="btnSave" 
                    Content="✅ עדכן שינויים" 
                    Click="Save_Click" 
                    Height="45" 
                    Margin="0,30,0,0" 
                    Background="#2ECC71" 
                    Foreground="White" 
                    FontSize="16" 
                    FontWeight="Bold" 
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>

        </StackPanel>
    </Grid>
</Window>